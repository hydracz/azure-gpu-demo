# 05-production 默认配置。
# apply.sh 会自动读取这个文件；执行命令时传入的同名环境变量会覆盖这里的值。

# 应用名，同时作为 namespace、Service、Gateway、Deployment 等资源名的基础。
# 必须符合 Kubernetes DNS label 规则：小写字母、数字和中划线，且首尾不能是中划线。
APP_NAME=production-app

# 业务镜像地址。请在部署前改成客户自己的镜像。
IMAGE_URL=

# 容器启动命令。通过 /bin/sh -lc 执行，因此可以写带参数的完整命令。
CONTAINER_COMMAND='sleep 10000'

# Azure Managed Prometheus 查询入口，对应环境阶段输出的 MONITOR_WORKSPACE_QUERY_ENDPOINT。
MONITOR_WORKSPACE_QUERY_ENDPOINT=https://amw-aks-karpgpu-004498-hdbme7b7c0hph6h8.southeastasia.prometheus.monitor.azure.com
