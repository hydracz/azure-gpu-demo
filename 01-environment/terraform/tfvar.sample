// Advanced override reference only.
// Preferred workflow: maintain root aks.env as the single input source,
// then let 01-plan.sh / 03-destroy.sh render *.auto.tfvars.json automatically.

subscription_id              = "00000000-0000-0000-0000-000000000000"
location                     = "southeastasia"
resource_group_name          = "rg-aks-karpenter-gpu"
cluster_name                 = "aks-karpenter-gpu"
existing_acr_id              = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/custom-images/providers/Microsoft.ContainerRegistry/registries/acrkarpentergpu"
monitor_workspace_name       = "amw-aks-karpenter-gpu"
monitor_workspace_public_network_access_enabled = true
log_analytics_workspace_name = "log-aks-karpenter-gpu"
grafana_name                 = "amg-aks-karpenter-gpu"
grafana_major_version        = 12

diagnostic_setting_name = "aks-all-logs"

# 由顶层 00-prepare 负责网络准备；这里直接引用已经准备好的 subnet id。
existing_subnet_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-aks-karpenter-gpu-net/providers/Microsoft.Network/virtualNetworks/vnet-aks-karpenter-gpu/subnets/snet-aks-underlay"

system_pool_name  = "sysd4"
system_vm_size    = "Standard_D4ads_v6"
system_node_count = 3
aks_admin_username = "azureuser"
aks_identity_name  = "id-aks-control-plane"

service_cidr   = "172.16.32.0/19"
dns_service_ip = "172.16.32.10"
blob_driver_enabled = true
istio_service_mesh_enabled             = true
istio_revisions                        = ["asm-1-27"]
istio_internal_ingress_gateway_enabled = true
istio_external_ingress_gateway_enabled = true
istio_internal_ingress_gateway_min_replicas = 2
istio_internal_ingress_gateway_max_replicas = 5
istio_external_ingress_gateway_min_replicas = 2
istio_external_ingress_gateway_max_replicas = 5
istio_kiali_enabled                         = true
istio_kiali_namespace                       = "aks-istio-system"
istio_kiali_replicas                        = 1
istio_kiali_view_only_mode                  = true
istio_kiali_operator_chart_version          = "2.20.0"
istio_kiali_prometheus_retention_period     = "30d"
istio_kiali_prometheus_scrape_interval      = "30s"
istio_kiali_proxy_identity_name             = "id-aks-istio-kiali-proxy"
istio_kiali_proxy_service_account_name      = "azuremonitor-query"
istio_kiali_proxy_service_name              = "azuremonitor-query"

# 需要给当前使用者或运维组赋权时, 传入 object id / principal id 列表。
grafana_admin_principal_ids = []
prometheus_rule_group_enabled  = true
prometheus_rule_group_interval = "PT1M"
service_monitor_crd_enabled    = true
keda_prometheus_auth_name      = "azure-managed-prometheus"
keda_prometheus_identity_name  = "id-keda-prometheus"
keda_prometheus_operator_namespace            = "kube-system"
keda_prometheus_operator_service_account_name = "keda-operator"
keda_prometheus_operator_deployment_name      = "keda-operator"

karpenter_namespace        = "kube-system"
karpenter_service_account  = "karpenter-sa"
karpenter_identity_name    = "id-karpenter-gpu"
karpenter_image_repository = "<acr-login-server>/quay.io/hydracz/karpenter-controller"
karpenter_image_tag        = "v20260323-dev"

gpu_sku_name          = "Standard_NC128lds_xl_RTXPRO6000BSE_v6"
gpu_type              = "rtxpro6000-bse"
gpu_node_workload_label = "gpu-test"
gpu_zones             = ["southeastasia-1"]
gpu_node_image_family = "Ubuntu2404"
gpu_os_disk_size_gb   = 1024
install_gpu_drivers   = false
consolidate_after     = "10m"
spot_max_price        = "-1"

gpu_operator_enabled              = true
gpu_operator_namespace            = "gpu-operator"
gpu_driver_cr_name                = "rtxpro6000-azure"
gpu_driver_node_selector_key      = "karpenter.azure.com/sku-gpu-name"
gpu_driver_node_selector_value    = ""
gpu_driver_source_repository      = "docker.io/yingeli"
gpu_driver_image                  = "driver"
gpu_driver_version                = "580.105.08"
gpu_driver_require_matching_nodes = false
gpu_driver_version_source_tag_2204 = "580.105.08-ubuntu22.04"
gpu_driver_version_source_tag_2404 = "580.105.08-ubuntu24.04"

tags = {
  environment = "dev"
  owner       = "platform"
}