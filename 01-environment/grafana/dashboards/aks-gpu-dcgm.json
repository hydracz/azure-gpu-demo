        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "avg(avg_over_time(DCGM_FI_PROF_PIPE_TENSOR_ACTIVE{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$service\",exported_namespace=~\"$workload_namespace\",exported_pod=~\"$workload_pod\",hostname=~\"$hostname\",gpu=~\"$gpu\",modelname=~\"$model\",gpu_i_profile=~\"$profile\"}[$__range])) * 100",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Average Compute Utilization",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
