          "editorMode": "code",
          "expr": "max(max_over_time(DCGM_FI_PROF_PIPE_TENSOR_ACTIVE{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$service\",exported_namespace=~\"$workload_namespace\",exported_pod=~\"$workload_pod\",hostname=~\"$hostname\",gpu=~\"$gpu\",modelname=~\"$model\",gpu_i_profile=~\"$profile\"}[$__range])) * 100",
