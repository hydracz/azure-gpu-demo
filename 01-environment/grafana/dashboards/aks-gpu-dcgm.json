      "pluginVersion": "11.6.9",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "count(count by (hostname, gpu) (DCGM_FI_DEV_SM_CLOCK{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$service\",exported_namespace=~\"$workload_namespace\",exported_pod=~\"$workload_pod\",hostname=~\"$hostname\",gpu=~\"$gpu\",modelname=~\"$model\",gpu_i_profile=~\"$profile\"}))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Visible GPUs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
