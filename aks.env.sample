AZ_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
LOCATION=southeastasia

RESOURCE_GROUP=rg-aks-karpenter-gpu
CLUSTER_NAME=aks-karpenter-gpu
ACR_NAME=acrkarpentergpu
MONITOR_WORKSPACE_NAME=amw-aks-karpenter-gpu
LOG_ANALYTICS_WORKSPACE_NAME=log-aks-karpenter-gpu
AKS_DIAGNOSTIC_SETTING_NAME=aks-all-logs
GRAFANA_NAME=amg-aks-karpenter-gpu

# --- Custom Network (customer-managed / pre-created) ---
# 如果已经提前创建好了网络, 直接填写 VNET_SUBNET_ID 并跳过 05-create-network.sh
NETWORK_RESOURCE_GROUP=rg-aks-karpenter-gpu-network
VNET_NAME=vnet-aks-karpenter-gpu
VNET_ADDRESS_PREFIX=10.240.0.0/16
AKS_SUBNET_NAME=snet-aks-underlay
AKS_SUBNET_ADDRESS_PREFIX=10.240.0.0/20
VNET_SUBNET_ID=

# --- System Node Pool (managed by AKS, no autoscaler) ---
SYSTEM_POOL_NAME=sysd4
SYSTEM_VM_SIZE=Standard_D4ads_v6
SYSTEM_NODE_COUNT=3
AKS_ENABLE_BLOB_DRIVER=true

# --- Karpenter ---
KARPENTER_NAMESPACE=kube-system
KARPENTER_SERVICE_ACCOUNT=karpenter-sa
KARPENTER_IDENTITY_NAME=id-karpenter-gpu
KARPENTER_IMAGE_REPO=quay.io/hydracz/karpenter-controller
KARPENTER_IMAGE_TAG=v20260323-dev

# --- Karpenter NodePool 配置 (GPU) ---
# 固定 GPU SKU 名称
GPU_SKU_NAME=Standard_NC128lds_xl_RTXPRO6000BSE_v6
# GPU 类型标签
GPU_TYPE=rtxpro6000-bse
# GPU 节点可用区, 逗号分隔
GPU_ZONES=southeastasia-1
# 通过 1 TiB OS disk 请求优先命中本地 NVMe ephemeral OS disk
GPU_OS_DISK_SIZE_GB=1024
# 跳过 GPU 驱动安装 (交由 GPU Operator 或外部机制管理)
INSTALL_GPU_DRIVERS=false
# GPU Operator 部署时同步上游 driver 镜像到当前 ACR
GPU_DRIVER_SYNC_ENABLED=true
# 本地 skopeo 如需 sudo 才能 push, 设为 true
GPU_DRIVER_SYNC_USE_SUDO=false
# 空闲多久后缩容 (consolidateAfter)
CONSOLIDATE_AFTER=10m
# Spot 最高价 (-1 = 不限制, 按需价上限; >= 0 = 指定单价)
SPOT_MAX_PRICE=-1

# --- 测试应用 ---
APP_NAMESPACE=gpu-test
APP_NAME=gpu-probe
TEST_IMAGE_REPOSITORY=aks/gpu-probe
TEST_IMAGE_TAG=latest

# 因为 GPU VM 128 核, 每个 Pod 独占整个节点, 副本数即节点数
APP_MIN_REPLICAS=1
APP_MAX_REPLICAS=2

APP_REQUEST_CPU=1000m
APP_LIMIT_CPU=2000m
APP_REQUEST_MEMORY=4Gi
APP_LIMIT_MEMORY=8Gi
# GPU 资源请求 (nvidia.com/gpu)
APP_REQUEST_GPU=1

# --- 验证 ---
LOCAL_FORWARD_PORT=18080
