AZ_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
LOCATION=southeastasia

# 统一环境 id。大多数资源名会基于它自动推导，例如：
# RESOURCE_GROUP=rg-aks-${STACK_ID}
# CLUSTER_NAME=aks-${STACK_ID}
# ACR_NAME=acr${STACK_ID 去掉非字母数字}
STACK_ID=karpgpu-dev01

# 如果已经提前创建好了子网，直接填写；留空表示由 shell/terraform 创建网络。
# 填写时必须保证这个 subnet id 在 Azure 中真实存在，否则 plan 阶段会直接报错。
EXISTING_VNET_SUBNET_ID=

# 如果已经提前创建好了 ACR，直接填写完整资源 ID；留空表示按 STACK_ID/ACR_NAME 规则创建或复用。
# EXISTING_ACR_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.ContainerRegistry/registries/<name>

# 可选：Grafana 管理员 object id，逗号分隔；留空时会自动使用当前 az login 用户/主体的 object id。
# GRAFANA_ADMIN_PRINCIPAL_IDS=

# 可选：通用资源标签。
TAGS_ENVIRONMENT=dev
TAGS_OWNER=platform

# Terraform backend 也从 aks.env 读取。至少需要填写状态存储所在的资源组和存储账号。
TFSTATE_RESOURCE_GROUP=rg-tfstate-example
TFSTATE_STORAGE_ACCOUNT=satfstateexample
TFSTATE_CONTAINER=tfstate
# 不填写时，00-init.sh 默认会生成 azure-gpu-demo/01-environment/<env-name>.tfstate
# TFSTATE_KEY=azure-gpu-demo/01-environment/dev.tfstate
TFSTATE_USE_AZUREAD_AUTH=true

# 共享镜像同步后端。默认 az-acr-import；若 ACR import 长时间卡住，可切换成 skopeo。
# 使用 skopeo 时，要求本机已安装 skopeo。
# skopeo 默认复制源镜像里全部架构，不跟随当前执行机架构；可选 all、system、index-only。
# IMAGE_SYNC_TOOL=skopeo
# IMAGE_SYNC_SKOPEO_MULTI_ARCH=all

# GPU 规格。其余 GPU / Karpenter / Istio / workload 参数默认都在 common.sh 中统一补齐。
GPU_SKU_NAME=Standard_NC128lds_xl_RTXPRO6000BSE_v6
GPU_TYPE=rtxpro6000-bse
GPU_ZONES=southeastasia-1
GPU_NODE_WORKLOAD_LABEL=gpu-test

# Qwen 外部镜像源。若目标 ACR 中已存在同 tag 镜像，密码可留空。
QWEN_LOADTEST_SOURCE_LOGIN_SERVER=qwenloadtestsea3414.azurecr.io
QWEN_LOADTEST_SOURCE_IMAGE_REPOSITORY=qwen-loadtest-target
QWEN_LOADTEST_SOURCE_IMAGE_TAG=sea-a100-failfast-20260413
QWEN_LOADTEST_SOURCE_PASSWORD=

# 00-prepare/10-sync-qwen-model.sh 会把这个外部私有镜像导入你自己的目标 ACR。
# 若目标 ACR 中已存在同 tag 镜像，密码可留空。
# QWEN_LOADTEST_SOURCE_USERNAME=qwenloadtestsea3414

# 可选高级覆盖项：只有在你不想使用基于 STACK_ID 的默认派生规则时再打开。
# CERT_MANAGER_ACME_EMAIL=you@example.com
# CERT_MANAGER_INGRESS_CLASS_NAME=istio
# CERT_MANAGER_STAGING_ISSUER_NAME=letsencrypt-staging
# CERT_MANAGER_PROD_ISSUER_NAME=letsencrypt-prod
# GRAFANA_DASHBOARD_IMPORT_ENABLED=true
# ISTIO_REVISIONS_CSV=asm-1-27
# ISTIO_EXTERNAL_INGRESS_GATEWAY_ENABLED=true
# ISTIO_INTERNAL_INGRESS_GATEWAY_ENABLED=true
# KEDA_PROMETHEUS_AUTH_NAME=azure-managed-prometheus
# RESOURCE_GROUP=rg-aks-karpgpu-custom
# NETWORK_RESOURCE_GROUP=rg-aks-karpgpu-custom-net
# CLUSTER_NAME=aks-karpgpu-custom
# EXISTING_ACR_ID=/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/shared-images/providers/Microsoft.ContainerRegistry/registries/acrkarpgpucustom
# ACR_NAME=acrkarpgpucustom
# ACR_RESOURCE_GROUP=shared-images
# MONITOR_WORKSPACE_NAME=amw-aks-karpgpu-custom
# LOG_ANALYTICS_WORKSPACE_NAME=log-aks-karpgpu-custom
# GRAFANA_NAME=amg-aks-karpgpu-custom
# VNET_NAME=vnet-aks-karpgpu-custom
